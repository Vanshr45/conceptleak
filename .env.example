# ConceptLeak Environment Configuration
# Copy this to .env and fill in your values

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# App Configuration
EXPO_PUBLIC_APP_NAME=ConceptLeak
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_DATA=true
EXPO_PUBLIC_DEBUG_MODE=false

# Optional: Analytics (if using)
# EXPO_PUBLIC_ANALYTICS_KEY=your_key_here

# Optional: Error Tracking (if using Sentry, etc)
# EXPO_PUBLIC_SENTRY_DSN=your_dsn_here
